{
  "name": "access-atlas-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Frontend tooling for Access Atlas.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build:vendor": "node scripts/build-vendor.mjs",
    "build:css": "postcss static/css/src/app.css -o static/css/app.css",
    "build:frontend": "pnpm build:vendor && pnpm build:css",
    "watch:css": "postcss static/css/src/app.css -o static/css/app.css --watch",
    "lint:frontend": "biome check --error-on-warnings static/js static/css/src",
    "format:frontend": "biome format --write static/js static/css/src",
    "format:frontend:check": "biome format --check static/js static/css/src"
  },
  "dependencies": {
    "@tabler/core": "1.4.0",
    "@tabler/icons-webfont": "3.44.0",
    "chart.js": "^4.5.1",
    "flatpickr": "4.6.13",
    "frappe-gantt": "^1.2.2",
    "htmx.org": "2.0.10",
    "leaflet": "1.9.4",
    "leaflet-ant-path": "1.3.0",
    "leaflet.fullscreen": "5.3.1",
    "photoswipe": "^5.4.4",
    "three": "0.183.2",
    "three-globe": "2.45.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
