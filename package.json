{
  "name": "access-atlas-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Frontend tooling for Access Atlas.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build:css": "postcss static/css/src/app.css -o static/css/app.css",
    "watch:css": "postcss static/css/src/app.css -o static/css/app.css --watch",
    "lint:js": "biome check static/js static/css/src",
    "format:js": "biome format --write static/js static/css/src",
    "format:js:check": "biome format --check static/js static/css/src"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "postcss": "^8.5.13",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
