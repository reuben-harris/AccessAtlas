# Django runtime settings.
DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgres://access_atlas:access_atlas@localhost:5432/access_atlas

# Uploaded file storage: local or s3.
MEDIA_STORAGE_BACKEND=local

# Local uploaded file storage. Used only when MEDIA_STORAGE_BACKEND=local.
MEDIA_ROOT=media
MEDIA_URL=/media/

# S3-compatible uploaded file storage. Used only when MEDIA_STORAGE_BACKEND=s3.
# AWS_STORAGE_BUCKET_NAME is required for S3. The other values depend on the
# provider; AWS_S3_ENDPOINT_URL is useful for MinIO, R2, or Spaces.
AWS_STORAGE_BUCKET_NAME=access-atlas-media
AWS_S3_REGION_NAME=ap-southeast-2
AWS_S3_ENDPOINT_URL=https://s3.ap-southeast-2.amazonaws.com
AWS_S3_CUSTOM_DOMAIN=access-atlas-media.example.com
AWS_QUERYSTRING_AUTH=true

# Authentication mode: local, oidc, or local-oidc.
AUTH_MODE=local

# Required when AUTH_MODE is oidc or local-oidc.
OIDC_PROVIDER_ID=access-atlas
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_SERVER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_FETCH_USERINFO=true
OIDC_PKCE_ENABLED=true
# Optional: client_secret_basic or client_secret_post.
OIDC_TOKEN_AUTH_METHOD=

# Access Atlas application settings.
SITE_FEED_URL=http://127.0.0.1:8000/dummy/site-feed.json
SITE_FEED_TOKEN=dev-token
# Defaults to the Access Atlas GitHub issues page. Set to a different tracker
# URL to override it, or set to an empty value to hide the Report bug button.
BUG_REPORT_URL=https://github.com/reuben-harris/AccessAtlas/issues/new
