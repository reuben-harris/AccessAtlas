# Django runtime settings.
DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgres://access_atlas:access_atlas@localhost:5432/access_atlas
MEDIA_URL=/media/
MEDIA_ROOT=media
# local or s3.
MEDIA_STORAGE_BACKEND=local

# Required when MEDIA_STORAGE_BACKEND=s3.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
# Optional for S3-compatible providers such as MinIO, R2, or Spaces.
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=true

# Authentication mode: local, oidc, or local-oidc.
AUTH_MODE=local

# Required when AUTH_MODE is oidc or local-oidc.
OIDC_PROVIDER_ID=access-atlas
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_SERVER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_FETCH_USERINFO=true
OIDC_PKCE_ENABLED=true
# Optional: client_secret_basic or client_secret_post.
OIDC_TOKEN_AUTH_METHOD=

# Access Atlas application settings.
SITE_FEED_URL=http://127.0.0.1:8000/dummy/site-feed.json
SITE_FEED_TOKEN=dev-token
